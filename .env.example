# All market data the dashboard needs is PUBLIC and KEYLESS — copy this file to
# .env only if you want to light up the optional premium factors. Leave any key
# blank and its factor simply stays a "needs API key" stub (the app never breaks).
#
#   cp .env.example .env

# Spot BTC ETF net inflow (flows)         — e.g. SoSoValue / Farside
PUBLIC_ETF_KEY=

# DXY / US Treasury yields (flows)        — FRED
PUBLIC_FRED_KEY=

# MVRV / SOPR / exchange netflow (onchain) — Glassnode
PUBLIC_GLASSNODE_KEY=
# ...or CryptoQuant
PUBLIC_CRYPTOQUANT_KEY=

# Liquidation heatmap (overlooked)        — Coinglass
PUBLIC_COINGLASS_KEY=

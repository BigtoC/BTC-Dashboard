---
import '../styles/dashboard.css';
import favicon from '../lib/images/icon.png';
// Default (no-JS) paint is Chinese, matching the original. The client script
// (`app.ts`) hydrates the data and applies the persisted language on load.
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={favicon.src} />
    <title>BTC 多周期涨跌综合预判系统 · Binance</title>
    <meta
      name="description"
      content="BTC multi-timeframe up/down composite prediction dashboard, powered by Binance public market data."
    />
  </head>
  <body>
    <div class="wrap">
      <header>
        <div class="brand">
          <span data-i18n="chrome.brand">BTC 多周期涨跌综合预判系统</span>
          <small data-i18n="chrome.subtitle"
            >数据源:Binance(现货 + 永续)· 含 Deribit 期权 · 每秒实时 · 仅供研究,非投资建议</small
          >
        </div>
        <div class="price-box">
          <span class="price" id="price">--</span>
          <span class="chg" id="chg">--</span>
          <canvas id="spark" width="130" height="36"></canvas>
        </div>
        <div class="spacer"></div>
        <div class="ctrl">
          <span class="switch" id="liveSwitch"
            ><span class="dot" id="liveDot"></span><span id="liveText">未连接</span></span
          >
          <span class="tick" id="updated">--:--:--</span>
          <button class="btn" id="refreshBtn" data-i18n="chrome.refresh">⟳ 刷新</button>
          <button class="btn lang" id="langBtn" data-i18n="chrome.langSwitch" aria-label="Toggle language">EN</button>
          <a
            class="btn gh"
            id="ghBtn"
            href="https://github.com/BigtoC/BTC-Dashboard"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub repository"
          >
            <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true" fill="currentColor"
              ><path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
              ></path></svg
            >
          </a>
        </div>
      </header>
      <div id="topErr"></div>
      <div class="grid" id="tfGrid">
        <div class="loading" data-i18n="chrome.loading" style="grid-column:1/-1">正在加载 Binance 实时数据…</div>
      </div>
      <div class="panels">
        <div class="panel">
          <h3>
            <span data-i18n="chrome.breakdownTitle">判断依据 · 因子明细</span>
            <span id="selTf" style="color:var(--accent)"></span>
          </h3>
          <div class="sub" data-i18n="chrome.breakdownSub">
            点击上方任一周期卡片查看完整因子拆解。每个因子方向分 -100 看空 ~ +100 看多。
          </div>
          <div id="breakdown"><div class="loading" data-i18n="chrome.selectTf">选择一个周期…</div></div>
        </div>
        <div class="panel-col">
          <div class="panel">
            <h3 data-i18n="chrome.globalTitle">全局市场状态</h3>
            <div class="sub" data-i18n="chrome.globalSub">跨周期共享的衍生品、期权、情绪、链上与资金流读数。</div>
            <div class="gauge" id="globalGauge"></div>
            <div class="legend">
              <span><i class="sw" style="background:var(--long)"></i><span data-i18n="chrome.legendLong">看多</span></span>
              <span
                ><i class="sw" style="background:var(--neutral)"></i
                ><span data-i18n="chrome.legendNeutral">中性</span></span
              >
              <span><i class="sw" style="background:var(--short)"></i><span data-i18n="chrome.legendShort">看空</span></span>
            </div>
          </div>
          <div class="panel">
            <h3 data-i18n="chrome.agentTitle">Agent</h3>
            <div id="agentPanel"></div>
          </div>
        </div>
      </div>
      <div class="disclaimer" data-i18n-html="chrome.disclaimer">
        <b>⚠ 风险与说明:</b> 数据源为 <b>Binance</b>(现货 + BTCUSDT 永续),叠加 <b>Deribit 期权</b>、Alternative.me、CoinGecko、mempool.space。趋势主导加权评分给出方向与置信度,<b>不构成投资建议</b>。引擎已“果断化”,价格逐笔实时跳动、判断每秒重算。期权因子已接入 <span class="pill ok">已接入</span>;标记 <span class="pill">需接入</span> 的为付费数据源(ETF/Glassnode/CryptoQuant/Coinglass/宏观),已预留接口、密钥留空不影响运行。部分海外源(Binance/Deribit/恐惧贪婪/CoinGecko)在部分地区可能不可达,会自动降级、不影响主评分。杠杆合约风险极高,务必自设止损与仓位管理。
      </div>
    </div>
    <script>
      import '../scripts/app.ts';
    </script>
  </body>
</html>
